# aginiti-redteam environment variables
# Copy this file to .env and fill in your keys. Never commit .env to git.
#
# LiteLLM discovers the correct API key automatically from the env vars below
# based on the model prefix (gemini/... → GEMINI_API_KEY, openai/... → OPENAI_API_KEY, etc.)
# Set only the key(s) for the provider(s) you actually use.

# ── LLM Provider API Keys ────────────────────────────────────────────────────

# Google Gemini (default provider — required if using gemini/* models)
GEMINI_API_KEY=

# OpenAI (set if using openai/* models, e.g. AGENT_MODEL=openai/gpt-4o)
OPENAI_API_KEY=

# Anthropic Claude (set if using anthropic/* models, e.g. AGENT_MODEL=anthropic/claude-sonnet-4-5)
# NOTE: Anthropic has no embeddings API — this key can only ever cover the
# AGENT_MODEL/llm_provider half below, never EMBED_MODEL.
ANTHROPIC_API_KEY=

# Groq (set if using groq/* models for AGENT_MODEL / llm_provider)
# NOTE: Groq has no embeddings API either (verified against console.groq.com/docs
# 2026-07-05 — Chat, Responses, Audio, Models, Batches, Files, Fine-Tuning only,
# no /embeddings). This key can only ever cover AGENT_MODEL/llm_provider, never
# EMBED_MODEL — pair it with a key below that actually has embeddings.
GROQ_API_KEY=

# Mistral (set if using EMBED_MODEL=mistral/mistral-embed — free "La Plateforme"
# tier, sign up at console.mistral.ai, no card required)
MISTRAL_API_KEY=

# ── Model Overrides (optional — defaults shown) ───────────────────────────────

# LLM used by reference agents for answer generation. Default:
# gemini/gemini-3.5-flash (gemini-2.0-flash was retired by Google — do not
# switch back to it). Any litellm-supported provider works. Groq
# (groq/llama-3.3-70b-versatile) is a cost-saving alternative — confirmed
# working — but its free-tier daily (TPD) token quota was a recurring
# blocker on completing a full benchmark run (see docs/how-it-works.md §6),
# so Gemini is the documented default again as of 2026-07-17. The
# scripts/run_healthcare_benchmark.py preset uses Gemini as its primary
# attacker LLM with Groq configured as the fallback provider.
AGENT_MODEL=gemini/gemini-3.5-flash

# Embedding model. DEFAULT IS NOW LOCAL AND FREE: chromadb/all-MiniLM-L6-v2
# runs on ChromaDB's bundled ONNX runtime — no API key, no PyTorch, no GPU.
# The model (~90MB) downloads once on first use and is cached at
# ~/.cache/chroma/onnx_models/. Used for BOTH agent retrieval and IKEA's
# attacker-side ERS/TRDM math (IKEAAttack does NOT read this env var — pass
# embed_model= explicitly; scripts/run_ikea.py wires it up).
EMBED_MODEL=chromadb/all-MiniLM-L6-v2
# Cloud alternatives (optional, cost money, need the matching key above):
# EMBED_MODEL=gemini/gemini-embedding-001      # requires GEMINI_API_KEY
# EMBED_MODEL=openai/text-embedding-3-small    # requires OPENAI_API_KEY
# EMBED_MODEL=mistral/mistral-embed            # requires MISTRAL_API_KEY
# Note: if you change this after seeding, re-seed the agent (seed.py --force) —
# a ChromaDB collection is pinned to the embedding model it was built with.
